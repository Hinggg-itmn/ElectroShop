@* Partial View: _PageHeader.cshtml
   Cách dùng:
   @await Html.PartialAsync("_PageHeader", new ViewDataDictionary(ViewData)
   {
       { "Title", "Tên trang" },
       { "Breadcrumb", new[] { ("Home", "/"), ("Trang hiện tại", "") } }
   })
   
   Hoặc đơn giản hơn — truyền qua ViewBag từ Controller:
       ViewBag.PageTitle = "Giỏ hàng";
       ViewBag.BreadcrumbParent = "Trang chủ";
*@

@{
    var pageTitle      = ViewData["PageTitle"]      as string ?? ViewBag.PageTitle ?? "Trang";
    var parentName     = ViewData["ParentName"]     as string ?? "Trang chủ";
    var parentUrl      = ViewData["ParentUrl"]      as string ?? "/";
    var parentName2    = ViewData["ParentName2"]    as string;   // tuỳ chọn cấp 2
    var parentUrl2     = ViewData["ParentUrl2"]     as string ?? "#";
}

<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">@pageTitle</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb animated slideInDown">
                <li class="breadcrumb-item">
                    <a href="@parentUrl" class="text-white">@parentName</a>
                </li>
                @if (!string.IsNullOrEmpty(parentName2))
                {
                    <li class="breadcrumb-item">
                        <a href="@parentUrl2" class="text-white">@parentName2</a>
                    </li>
                }
                <li class="breadcrumb-item text-primary active" aria-current="page">@pageTitle</li>
            </ol>
        </nav>
    </div>
</div>
