<!-- ═══ Navbar ════════════════════════════════════════════════════════ -->
<div class="container-fluid nav-bar p-0">
    <div class="row gx-0 bg-primary px-5 align-items-center">

        <!-- Category sidebar (desktop) -->
        <div class="col-lg-3 d-none d-lg-block">
            <nav class="navbar navbar-light position-relative" style="width:250px;">
                <button class="navbar-toggler border-0 fs-4 w-100 px-0 text-start"
                        type="button" data-bs-toggle="collapse" data-bs-target="#allCat">
                    <h4 class="m-0"><i class="fa fa-bars me-2"></i>Tất cả danh mục</h4>
                </button>
                <div class="collapse navbar-collapse rounded-bottom" id="allCat">
                    <div class="navbar-nav ms-auto py-0">
                        <ul class="list-unstyled categories-bars">
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Laptops">Laptops &amp; Máy tính</a>
                                <span>(2)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Smartphones">Điện thoại &amp; Tablet</a>
                                <span>(2)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Cameras">Máy ảnh</a>
                                <span>(2)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Audio">Âm thanh</a>
                                <span>(2)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="TVs">Smart TV</a>
                                <span>(1)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Wearables">Wearables</a>
                                <span>(1)</span>
                            </div></li>
                            <li><div class="categories-bars-item">
                                <a asp-controller="Shop" asp-action="Index" asp-route-category="Drones">Drone</a>
                                <span>(1)</span>
                            </div></li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>

        <!-- Main navbar -->
        <div class="col-12 col-lg-9">
            <nav class="navbar navbar-expand-lg navbar-light bg-primary">

                <!-- Mobile brand -->
                <a asp-controller="Home" asp-action="Index" class="navbar-brand d-block d-lg-none">
                    <h1 class="display-5 text-secondary m-0">
                        <i class="fas fa-shopping-bag text-white me-2"></i>Electro
                    </h1>
                </a>

                <button class="navbar-toggler ms-auto" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="fa fa-bars fa-1x"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto py-0">

                        <a asp-controller="Home" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                            Trang chủ
                        </a>

                        <a asp-controller="Shop" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shop" ? "active" : "")">
                            Cửa hàng
                        </a>

                        <!-- Dropdown: Trang -->
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Trang</a>
                            <div class="dropdown-menu m-0">
                                <a asp-controller="Shop"     asp-action="Bestseller" class="dropdown-item">
                                    <i class="fas fa-fire me-2"></i>Bán chạy nhất
                                </a>
                                <a asp-controller="Cart"     asp-action="Index"      class="dropdown-item">
                                    <i class="fas fa-shopping-cart me-2"></i>Giỏ hàng
                                </a>
                                <a asp-controller="Checkout" asp-action="Index"      class="dropdown-item">
                                    <i class="fas fa-credit-card me-2"></i>Thanh toán
                                </a>
                                <a asp-controller="About"    asp-action="Index"      class="dropdown-item">
                                    <i class="fas fa-info-circle me-2"></i>Giới thiệu
                                </a>
                                <div class="dropdown-divider"></div>
                                <a asp-controller="Error"    asp-action="Index"
                                   asp-route-statusCode="404"                        class="dropdown-item">
                                    <i class="fas fa-exclamation-triangle me-2"></i>Trang 404
                                </a>
                            </div>
                        </div>

                        <!-- Dropdown: Tài khoản -->
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fas fa-user me-1"></i>Tài khoản
                            </a>
                            <div class="dropdown-menu m-0">
                                <a asp-controller="Account" asp-action="Login"    class="dropdown-item">
                                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                                </a>
                                <a asp-controller="Account" asp-action="Register" class="dropdown-item">
                                    <i class="fas fa-user-plus me-2"></i>Đăng ký
                                </a>
                                <div class="dropdown-divider"></div>
                                <a asp-controller="Account" asp-action="Logout"   class="dropdown-item">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </a>
                            </div>
                        </div>

                        <a asp-controller="Contact" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")">
                            Liên hệ
                        </a>

                    </div>

                    <a href="tel:+0123456789"
                       class="btn btn-secondary rounded-pill py-2 px-4 ms-3 mb-3 mb-lg-0">
                        <i class="fa fa-mobile-alt me-2"></i>+0123 456 7890
                    </a>
                </div>

            </nav>
        </div>

    </div>
</div>
