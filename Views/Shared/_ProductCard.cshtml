@model ElectroShop.Models.Product

<div class="product-item rounded">
    <div class="product-item-inner border rounded">
        <div class="product-item-inner-item">
            <img src="@Model.ImageUrl" class="img-fluid w-100 rounded-top" alt="@Model.Name"
                 style="height:220px;object-fit:contain;padding:1rem;" />

            @if (Model.IsNew)
            {
                <div class="product-new">Mới</div>
            }
            else if (Model.DiscountPercent.HasValue)
            {
                <div class="product-sale">-@Model.DiscountPercent%</div>
            }

            <div class="product-details">
                <a asp-controller="Shop" asp-action="Detail" asp-route-id="@Model.Id">
                    <i class="fa fa-eye fa-1x"></i>
                </a>
            </div>
        </div>
        <div class="text-center rounded-bottom p-4">
            <a asp-controller="Shop" asp-action="Index" asp-route-category="@Model.Category"
               class="d-block mb-2 text-muted small">@Model.Category</a>
            <a asp-controller="Shop" asp-action="Detail" asp-route-id="@Model.Id"
               class="d-block h5 mb-2">@Model.Name</a>
            <div>
                @if (Model.OldPrice.HasValue)
                {
                    <del class="me-2 text-muted">@Model.OldPrice.Value.ToVnd()</del>
                }
                <span class="text-primary fs-5 fw-bold">@Model.Price.ToVnd()</span>
            </div>
        </div>
    </div>
    <div class="product-item-add border border-top-0 rounded-bottom text-center p-4 pt-0">
        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
            <input type="hidden" name="productId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="1" />
            <button type="submit" class="btn btn-primary border-secondary rounded-pill py-2 px-4 mb-3">
                <i class="fas fa-shopping-cart me-2"></i>Thêm vào giỏ
            </button>
        </form>
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fas fa-star @(i <= Math.Round(Model.Rating) ? "text-primary" : "text-muted")"></i>
                }
            </div>
            <small class="text-muted">(@Model.ReviewCount)</small>
        </div>
    </div>
</div>
