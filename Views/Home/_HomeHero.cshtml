@* Partial View: _HomeHero.cshtml
   Gọi từ Home/Index.cshtml:
   @await Html.PartialAsync("_HomeHero", Model)
*@
@model ElectroShop.Models.ViewModels.HomeViewModel

<div class="container-fluid carousel bg-light px-0">
    <div class="row g-0 justify-content-end">

        <!-- Owl Carousel slides -->
        <div class="col-12 col-lg-7 col-xl-9">
            <div class="header-carousel owl-carousel bg-light py-5">
                <div class="row g-0 header-carousel-item align-items-center">
                    <div class="col-xl-6 carousel-img wow fadeInLeft" data-wow-delay="0.1s">
                        <img src="~/img/carousel-1.png" class="img-fluid w-100" alt="Laptop Sale" />
                    </div>
                    <div class="col-xl-6 carousel-content p-4">
                        <h4 class="text-uppercase fw-bold mb-4 wow fadeInRight"
                            data-wow-delay="0.1s" style="letter-spacing:3px;">
                            Tiết kiệm tới 10 triệu ₫
                        </h4>
                        <h1 class="display-3 text-capitalize mb-4 wow fadeInRight"
                            data-wow-delay="0.3s">
                            Laptop &amp; Máy tính được chọn lọc
                        </h1>
                        <p class="text-dark wow fadeInRight" data-wow-delay="0.5s">
                            Điều kiện và điều khoản được áp dụng
                        </p>
                        <a asp-controller="Shop" asp-action="Index"
                           class="btn btn-primary rounded-pill py-3 px-5 wow fadeInRight"
                           data-wow-delay="0.7s">Mua ngay</a>
                    </div>
                </div>
                <div class="row g-0 header-carousel-item align-items-center">
                    <div class="col-xl-6 carousel-img wow fadeInLeft" data-wow-delay="0.1s">
                        <img src="~/img/carousel-2.png" class="img-fluid w-100" alt="Smartphone" />
                    </div>
                    <div class="col-xl-6 carousel-content p-4">
                        <h4 class="text-uppercase fw-bold mb-4 wow fadeInRight"
                            data-wow-delay="0.1s" style="letter-spacing:3px;">
                            Tiết kiệm tới 5 triệu ₫
                        </h4>
                        <h1 class="display-3 text-capitalize mb-4 wow fadeInRight"
                            data-wow-delay="0.3s">
                            Điện thoại giá hời
                        </h1>
                        <p class="text-dark wow fadeInRight" data-wow-delay="0.5s">
                            Ưu đãi có hạn
                        </p>
                        <a asp-controller="Shop" asp-action="Index"
                           class="btn btn-primary rounded-pill py-3 px-5 wow fadeInRight"
                           data-wow-delay="0.7s">Xem ngay</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banner phải: sản phẩm nổi bật -->
        <div class="col-12 col-lg-5 col-xl-3 wow fadeInRight" data-wow-delay="0.1s">
            @if (Model.BestSellers.Any())
            {
                var featured = Model.BestSellers.First();
                <div class="carousel-header-banner h-100">
                    <img src="@featured.ImageUrl" class="img-fluid w-100 h-100"
                         style="object-fit:cover;" alt="@featured.Name" />
                    <div class="carousel-banner-offer">
                        @if (featured.DiscountPercent.HasValue)
                        {
                            <p class="bg-primary text-white rounded fs-5 py-2 px-4 mb-0 me-3">
                                -@featured.DiscountPercent%
                            </p>
                        }
                        <p class="text-primary fs-5 fw-bold mb-0">Ưu đãi đặc biệt</p>
                    </div>
                    <div class="carousel-banner">
                        <div class="carousel-banner-content text-center p-4">
                            <a asp-controller="Shop" asp-action="Index"
                               asp-route-category="@featured.Category"
                               class="d-block mb-2">@featured.Category</a>
                            <a asp-controller="Shop" asp-action="Detail"
                               asp-route-id="@featured.Id"
                               class="d-block text-white fs-5">@featured.Name</a>
                            @if (featured.OldPrice.HasValue)
                            {
                                <del class="me-2 text-white">@featured.OldPrice.Value.ToVnd()</del>
                            }
                            <span class="text-primary fs-5">@featured.Price.ToVnd()</span>
                        </div>
                        <form asp-controller="Cart" asp-action="Add" method="post">
                            <input type="hidden" name="productId" value="@featured.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn btn-primary rounded-pill py-2 px-4">
                                <i class="fas fa-shopping-cart me-2"></i>Thêm vào giỏ
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

    </div>
</div>
