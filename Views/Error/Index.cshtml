@{
    ViewData["Title"] = $"{ViewBag.StatusCode} Error";
    int code = ViewBag.StatusCode ?? 404;
}

<div class="container-fluid py-5 d-flex align-items-center" style="min-height:70vh;">
    <div class="container text-center wow fadeInUp" data-wow-delay="0.1s">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <h1 class="display-1 fw-bold text-primary">@code</h1>
                <h2 class="mb-4">
                    @if (code == 404) { <text>Page Not Found</text> }
                    else if (code == 500) { <text>Internal Server Error</text> }
                    else { <text>Something Went Wrong</text> }
                </h2>
                <p class="text-muted mb-5 fs-5">@ViewBag.Message</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-primary rounded-pill py-3 px-5">
                        <i class="fas fa-home me-2"></i>Back to Home
                    </a>
                    <a asp-controller="Shop" asp-action="Index"
                       class="btn btn-outline-primary rounded-pill py-3 px-5">
                        <i class="fas fa-store me-2"></i>Browse Shop
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
