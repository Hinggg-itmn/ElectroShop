@model ShopViewModel
@{
    ViewData["Title"] = "Cửa hàng";
}

@* ═══ Page Header (Partial View dùng chung) ════════════════════════════ *@
@await Html.PartialAsync("_PageHeader", new ViewDataDictionary(ViewData)
{
    { "PageTitle", "Cửa hàng" },
    { "ParentName", "Trang chủ" },
    { "ParentUrl",  "/" }
})

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row g-4">

            <!-- ── Sidebar lọc ──────────────────────────────────────── -->
            <div class="col-lg-3 col-xl-3">
                <div class="card border-0 shadow-sm rounded mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-primary">
                            <i class="fas fa-filter me-2"></i>Lọc sản phẩm
                        </h5>
                        <form asp-controller="Shop" asp-action="Index" method="get" id="filterForm">

                            <!-- Tìm kiếm -->
                            <div class="mb-4">
                                <label class="fw-semibold mb-2 d-block">Tìm kiếm</label>
                                <input type="text" name="query" class="form-control rounded-pill"
                                       placeholder="Tên sản phẩm..." value="@Model.Query" />
                            </div>

                            <!-- Danh mục -->
                            <div class="mb-4">
                                <label class="fw-semibold mb-2 d-block">Danh mục</label>
                                @foreach (var cat in Model.Categories)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="category"
                                               id="cat-@cat" value="@cat"
                                               @(Model.SelectedCategory == cat ? "checked" : "") />
                                        <label class="form-check-label" for="cat-@cat">@cat</label>
                                    </div>
                                }
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="category"
                                           id="cat-all" value=""
                                           @(string.IsNullOrEmpty(Model.SelectedCategory) ? "checked" : "") />
                                    <label class="form-check-label" for="cat-all">
                                        <em>Tất cả danh mục</em>
                                    </label>
                                </div>
                            </div>

                            <!-- Khoảng giá -->
                            <div class="mb-4">
                                <label class="fw-semibold mb-2 d-block">Khoảng giá (₫)</label>
                                <div class="d-flex gap-2">
                                    <input type="number" name="minPrice"
                                           class="form-control form-control-sm"
                                           placeholder="Từ" value="@Model.MinPrice" min="0" />
                                    <input type="number" name="maxPrice"
                                           class="form-control form-control-sm"
                                           placeholder="Đến" value="@Model.MaxPrice" min="0" />
                                </div>
                            </div>

                            <!-- Sắp xếp -->
                            <div class="mb-4">
                                <label class="fw-semibold mb-2 d-block">Sắp xếp theo</label>
                                <select name="sortBy" class="form-select">
                                    <option value=""           selected="@(Model.SortBy == null)">Mặc định</option>
                                    <option value="price_asc"  selected="@(Model.SortBy == "price_asc")">Giá: thấp → cao</option>
                                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Giá: cao → thấp</option>
                                    <option value="rating"     selected="@(Model.SortBy == "rating")">Đánh giá cao nhất</option>
                                    <option value="newest"     selected="@(Model.SortBy == "newest")">Mới nhất</option>
                                    <option value="bestseller" selected="@(Model.SortBy == "bestseller")">Bán chạy nhất</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 rounded-pill">
                                <i class="fas fa-search me-2"></i>Áp dụng bộ lọc
                            </button>
                            <a asp-controller="Shop" asp-action="Index"
                               class="btn btn-outline-secondary w-100 rounded-pill mt-2">
                                <i class="fas fa-times me-2"></i>Xoá bộ lọc
                            </a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- ── Lưới sản phẩm ────────────────────────────────────── -->
            <div class="col-lg-9 col-xl-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <p class="mb-0 text-muted">
                        Hiển thị <strong>@Model.TotalResults</strong> sản phẩm
                        @if (!string.IsNullOrEmpty(Model.Query))
                        {
                            <span> cho "<strong>@Model.Query</strong>"</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.SelectedCategory))
                        {
                            <span> trong <strong>@Model.SelectedCategory</strong></span>
                        }
                    </p>
                </div>

                @if (!Model.Products.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-search fa-4x text-muted mb-4"></i>
                        <h4 class="text-muted">Không tìm thấy sản phẩm nào</h4>
                        <p class="text-muted">Hãy thử điều chỉnh tiêu chí tìm kiếm hoặc bộ lọc.</p>
                        <a asp-controller="Shop" asp-action="Index"
                           class="btn btn-primary rounded-pill">Xem tất cả sản phẩm</a>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Products)
                        {
                            <div class="col-md-6 col-xl-4 wow fadeInUp" data-wow-delay="0.1s">
                                @await Html.PartialAsync("_ProductCard", product)
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
</div>
