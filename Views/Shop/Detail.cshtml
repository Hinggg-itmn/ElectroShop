@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Name;
    var p = Model.Product;
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">Mô tả sản phẩm</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb animated slideInDown">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index" class="text-white">Cửa hàng</a></li>
                <li class="breadcrumb-item text-primary active" aria-current="page">@p.Name</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row g-5">

            <!-- Product Images -->
            <div class="col-lg-5 wow fadeInLeft" data-wow-delay="0.1s">
                <div class="single-carousel owl-carousel">
                    <div class="single-product-img rounded">
                        <img src="@p.ImageUrl" class="img-fluid w-100 rounded"
                             style="height:400px;object-fit:contain;background:#f8f9fa;" alt="@p.Name"
                             data-dot="<img src='@p.ImageUrl' style='width:80px;height:60px;object-fit:contain;'>" />
                    </div>
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-7 wow fadeInRight" data-wow-delay="0.1s">
                <!-- Badges -->
                <div class="mb-3">
                    @if (p.IsNew) { <span class="badge bg-success me-2">MỚI</span> }
                    @if (p.IsBestSeller) { <span class="badge bg-warning text-dark me-2">BÁN CHẠY NHẤT</span> }
                    @if (p.IsFeatured) { <span class="badge bg-primary me-2">ĐẶC BIỆT</span> }
                    @if (p.DiscountPercent.HasValue) { <span class="badge bg-danger">-@p.DiscountPercent% GIẢM</span> }
                </div>

                <h1 class="mb-3">@p.Name</h1>

                <!-- Rating -->
                <div class="d-flex align-items-center mb-3">
                    <div class="d-flex me-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fas fa-star @(i <= Math.Round(p.Rating) ? "text-primary" : "text-muted")"></i>
                        }
                    </div>
                    <span class="text-muted">(@p.ReviewCount reviews)</span>
                    <span class="ms-3 @(p.Stock > 0 ? "text-success" : "text-danger")">
                        <i class="fas fa-circle me-1" style="font-size:10px;"></i>
                        @(p.Stock > 0 ? $"In Stock ({p.Stock} units)" : "Out of Stock")
                    </span>
                </div>

                <!-- Price -->
                <div class="mb-4">
                    @if (p.OldPrice.HasValue)
                    {
                        <del class="text-muted fs-4 me-3">$@p.OldPrice.Value.ToString("N2")</del>
                    }
                    <span class="text-primary display-5 fw-bold">$@p.Price.ToString("N2")</span>
                    @if (p.DiscountPercent.HasValue)
                    {
                        <span class="badge bg-danger ms-2 fs-6">Bạn được giảm @p.DiscountPercent%</span>
                    }
                </div>

                <!-- Description -->
                <p class="text-muted mb-4">@p.Description</p>

                <!-- Meta info -->
                <div class="mb-4">
                    <p class="mb-1"><strong>Thương hiệu:</strong> <span class="text-muted">@p.Brand</span></p>
                    <p class="mb-1"><strong>Loại:</strong>
                        <a asp-controller="Shop" asp-action="Index" asp-route-category="@p.Category"
                           class="text-primary">@p.Category</a>
                    </p>
                </div>

                <!-- Add to Cart form -->
                <form asp-controller="Cart" asp-action="Add" method="post" class="mb-4">
                    <input type="hidden" name="productId" value="@p.Id" />
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="quantity d-flex">
                            <button type="button" class="btn btn-outline-secondary btn-minus">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" name="quantity" class="form-control text-center border-0"
                                   value="1" min="1" max="@p.Stock" style="width:70px;" />
                            <button type="button" class="btn btn-outline-secondary btn-plus">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        @if (p.Stock > 0)
                        {
                            <button type="submit" class="btn btn-primary rounded-pill py-2 px-5">
                                <i class="fas fa-shopping-cart me-2"></i>Thêm vào giỏ
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary rounded-pill py-2 px-5" disabled>
                                Hết hàng
                            </button>
                        }
                    </div>
                </form>

                <!-- Checkout shortcut -->
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-outline-primary rounded-pill py-2 px-5">
                    <i class="fas fa-bolt me-2"></i>Mua ngay
                </a>
            </div>
        </div>

        <!-- ── Related Products ─────────────────────────────────────────── -->
        @if (Model.RelatedProducts.Any())
        {
            <div class="row g-4 mt-5">
                <div class="col-12 wow fadeInUp" data-wow-delay="0.1s">
                    <h3 class="mb-4 border-bottom pb-3">Sản phẩm liên quan</h3>
                </div>
                <div class="col-12">
                    <div class="related-carousel owl-carousel">
                        @foreach (var rel in Model.RelatedProducts)
                        {
                            <div class="col-12">
                                @await Html.PartialAsync("_ProductCard", rel)
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // Quantity buttons trên trang Detail
    $('.btn-plus').on('click', function () {
        var input = $(this).siblings('input');
        var max = parseInt(input.attr('max'));
        var val = parseInt(input.val());
        if (val < max) input.val(val + 1);
    });
    $('.btn-minus').on('click', function () {
        var input = $(this).siblings('input');
        var val = parseInt(input.val());
        if (val > 1) input.val(val - 1);
    });
</script>
}
