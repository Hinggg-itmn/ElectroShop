@model RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

@await Html.PartialAsync("_PageHeader", new ViewDataDictionary(ViewData)
{
    { "PageTitle", "Đăng ký" },
    { "ParentName", "Trang chủ" },
    { "ParentUrl",  "/" }
})

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 wow fadeInUp" data-wow-delay="0.1s">
            <div class="card border-0 shadow-sm rounded">
                <div class="card-body p-5">
                    <h3 class="text-center fw-bold mb-2">Tạo tài khoản</h3>
                    <p class="text-center text-muted mb-4">
                        Đăng ký để mua sắm và nhận ưu đãi độc quyền
                    </p>
                    <form asp-controller="Account" asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tên</label>
                                <input asp-for="FirstName" class="form-control rounded-pill"
                                       placeholder="Nguyễn" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Họ</label>
                                <input asp-for="LastName" class="form-control rounded-pill"
                                       placeholder="Văn A" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Email <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Email" type="email"
                                       class="form-control rounded-pill"
                                       placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Mật khẩu <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Password" type="password"
                                       class="form-control rounded-pill"
                                       placeholder="Ít nhất 8 ký tự" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Xác nhận mật khẩu <span class="text-danger">*</span>
                                </label>
                                <input asp-for="ConfirmPassword" type="password"
                                       class="form-control rounded-pill"
                                       placeholder="Nhập lại mật khẩu" />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           id="terms" required />
                                    <label class="form-check-label text-muted" for="terms">
                                        Tôi đồng ý với
                                        <a href="#" class="text-primary">Điều khoản dịch vụ</a>
                                        và
                                        <a href="#" class="text-primary">Chính sách bảo mật</a>
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit"
                                        class="btn btn-primary w-100 rounded-pill py-3 fw-bold">
                                    Tạo tài khoản
                                </button>
                                <div class="text-center mt-3">
                                    <span class="text-muted">Đã có tài khoản? </span>
                                    <a asp-controller="Account" asp-action="Login"
                                       class="text-primary fw-semibold">Đăng nhập</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
