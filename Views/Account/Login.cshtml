@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

@await Html.PartialAsync("_PageHeader", new ViewDataDictionary(ViewData)
{
    { "PageTitle", "Đăng nhập" },
    { "ParentName", "Trang chủ" },
    { "ParentUrl",  "/" }
})

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 wow fadeInUp" data-wow-delay="0.1s">
            <div class="card border-0 shadow-sm rounded">
                <div class="card-body p-5">
                    <h3 class="text-center fw-bold mb-2">Đăng nhập</h3>
                    <p class="text-center text-muted mb-4">Chào mừng bạn trở lại!</p>

                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger rounded">
                            <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
                        </div>
                    }
                    @if (TempData["RegisterSuccess"] != null)
                    {
                        <div class="alert alert-success rounded">
                            <i class="fas fa-check-circle me-2"></i>@TempData["RegisterSuccess"]
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" type="email"
                                   class="form-control rounded-pill py-3"
                                   placeholder="email@example.com" />
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label fw-semibold mb-0">Mật khẩu</label>
                                <a href="#" class="text-primary small">Quên mật khẩu?</a>
                            </div>
                            <input asp-for="Password" type="password"
                                   class="form-control rounded-pill py-3 mt-1"
                                   placeholder="Nhập mật khẩu" />
                        </div>
                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                            <label class="form-check-label text-muted">Ghi nhớ trong 30 ngày</label>
                        </div>
                        <button type="submit"
                                class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5">
                            Đăng nhập
                        </button>
                        <div class="text-center mt-4">
                            <span class="text-muted">Chưa có tài khoản? </span>
                            <a asp-controller="Account" asp-action="Register"
                               class="text-primary fw-semibold">Đăng ký miễn phí</a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="alert alert-info mt-3 rounded small">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Demo:</strong> <code>admin@electro.com</code> / <code>123456</code>
            </div>
        </div>
    </div>
</div>
