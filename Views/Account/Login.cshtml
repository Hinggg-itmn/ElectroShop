@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container-fluid page-header py-5">
    <div class="container py-5">
        <h1 class="display-3 text-white">Đăng nhập</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-white">Home</a>
                </li>
                <li class="breadcrumb-item text-primary active">Đăng nhập</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 wow fadeInUp">
            <div class="card border-0 shadow-sm rounded">
                <div class="card-body p-5">
                    <h3 class="text-center fw-bold mb-2">Đăng nhập</h3>
                    <p class="text-center text-muted mb-4">
                        Chào mừng bạn trở lại!
                    </p>

                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" type="email"
                                   class="form-control rounded-pill py-3"
                                   placeholder="email@example.com" />
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between">
                                <label class="form-label fw-semibold">Mật khẩu</label>
                                <a href="#" class="text-primary small">Quên mật khẩu?</a>
                            </div>
                            <input asp-for="Password" type="password"
                                   class="form-control rounded-pill py-3"
                                   placeholder="Nhập mật khẩu" />
                        </div>
                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" type="checkbox"
                                   class="form-check-input" />
                            <label class="form-check-label">Ghi nhớ trong 30 ngày</label>
                        </div>
                        <button type="submit"
                                class="btn btn-primary w-100 rounded-pill py-3 fw-bold">
                            Đăng nhập
                        </button>
                        <div class="text-center mt-3">
                            <span class="text-muted">Chưa có tài khoản? </span>
                            <a asp-action="Register" class="text-primary fw-semibold">
                                Đăng ký miễn phí
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>