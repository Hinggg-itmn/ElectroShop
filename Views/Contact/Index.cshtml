@model ContactViewModel
@{
    ViewData["Title"] = "Contact";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">Contact Us</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb animated slideInDown">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white">Home</a></li>
                <li class="breadcrumb-item text-primary active">Contact</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">

        <!-- Success alert -->
        @if (Model.IsSubmitted)
        {
            <div class="alert alert-success alert-dismissible fade show rounded mb-4" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Tin nhắn đã gửi!</strong> Chúng tôi sẽ phản hồi bạn trong vòng 24 giờ.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-5">
            <!-- Info Cards -->
            <div class="col-lg-4 wow fadeInLeft" data-wow-delay="0.1s">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-center rounded p-4 border">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:60px;height:60px;">
                            <i class="fas fa-map-marker-alt fa-lg text-white"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1">Address</h5>
                            <p class="mb-0 text-muted">123 Street, New York, USA</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center rounded p-4 border">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:60px;height:60px;">
                            <i class="fas fa-envelope fa-lg text-white"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1">Mail Us</h5>
                            <p class="mb-0 text-muted">info@electro.com</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center rounded p-4 border">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:60px;height:60px;">
                            <i class="fa fa-phone-alt fa-lg text-white"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1">Telephone</h5>
                            <p class="mb-0 text-muted">(+012) 3456 7890</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-8 wow fadeInRight" data-wow-delay="0.1s">
                <div class="card border-0 shadow-sm rounded">
                    <div class="card-body p-4 p-md-5">
                        <h4 class="fw-bold mb-4 text-primary">
                            <i class="fas fa-paper-plane me-2"></i>Send Us a Message
                        </h4>
                        <form asp-controller="Contact" asp-action="Index" method="post">
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Your Name</label>
                                    <input asp-for="Name" class="form-control rounded-pill" placeholder="John Doe" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Your Email</label>
                                    <input asp-for="Email" type="email" class="form-control rounded-pill"
                                           placeholder="john@example.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Subject</label>
                                    <input asp-for="Subject" class="form-control rounded-pill"
                                           placeholder="How can we help you?" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Message</label>
                                    <textarea asp-for="Message" class="form-control" rows="6"
                                              placeholder="Write your message here..."></textarea>
                                    <span asp-validation-for="Message" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary rounded-pill py-3 px-5">
                                        <i class="fas fa-paper-plane me-2"></i>Send Message
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
